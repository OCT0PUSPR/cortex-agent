# cortex-agent configuration — copy to .env and fill in.
# NEVER commit your real .env. All values below are placeholders.

# ============================================================================
# LLM API keys (read directly by the backends; never hardcoded in source)
# ============================================================================
# Anthropic Claude (used by --backend anthropic)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# HuggingFace (used by --backend hf, API mode)
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ============================================================================
# Agent / LLM (CORTEX_ prefix)
# ============================================================================
# Backend: mock (offline, default) | anthropic | hf | tinybrain (local model)
CORTEX_BACKEND=mock
# Model id override. Examples:
#   anthropic: claude-opus-4-8 | claude-sonnet-4-6 | claude-haiku-4-5
#   hf:        Qwen/Qwen2.5-7B-Instruct | meta-llama/Llama-3.1-8B-Instruct
#   tinybrain: a checkpoint dir, e.g. .cortex/tinybrain
CORTEX_MODEL=
# Comma-separated failover chain for the resilient backend.
CORTEX_FALLBACK_BACKENDS=hf,mock
CORTEX_MAX_STEPS=8
CORTEX_MAX_TOKENS=2048
CORTEX_TEMPERATURE=0.7
# Hard budgets that STOP the loop (defense against runaway cost / infinite loops)
CORTEX_MAX_TOTAL_TOKENS=100000
CORTEX_MAX_COST_USD=1.0
# Timeouts (seconds) and LLM retry attempts
CORTEX_RUN_TIMEOUT_SECONDS=300
CORTEX_LLM_TIMEOUT_SECONDS=60
CORTEX_LLM_MAX_RETRIES=3

# ============================================================================
# Tools / sandbox
# ============================================================================
CORTEX_WORKSPACE=.cortex/workspace
# Expose the network tool (http_get, SSRF-protected) to the agent
CORTEX_ENABLE_NETWORK_TOOLS=true
CORTEX_TOOL_TIMEOUT_SECONDS=15
# run_python sandbox resource limits
CORTEX_PYTHON_CPU_SECONDS=5
CORTEX_PYTHON_MEMORY_MB=256
CORTEX_PYTHON_WALL_SECONDS=10
CORTEX_HTTP_MAX_BYTES=100000
# Require human approval before dangerous tools (write_file/run_python/http_get)
CORTEX_REQUIRE_APPROVAL=false

# ============================================================================
# State (SQLAlchemy 2.0 async + Alembic)
# ============================================================================
# SQLite (default). For Postgres:
#   CORTEX_DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/cortex
#   CORTEX_SYNC_DATABASE_URL=postgresql+psycopg://user:pass@host:5432/cortex   (for Alembic)
CORTEX_DATABASE_URL=sqlite+aiosqlite:///./.cortex/cortex.db
CORTEX_SYNC_DATABASE_URL=
# Legacy file-based memory store (used by the sync Agent / CLI)
CORTEX_MEMORY_DB=.cortex/memory.sqlite
# Enable sentence-transformers vector recall when the package is installed
CORTEX_USE_VECTORS=false

# ============================================================================
# Queue / scale (optional; arq + Redis)
# ============================================================================
CORTEX_USE_QUEUE=false
CORTEX_REDIS_URL=redis://localhost:6379
CORTEX_MAX_CONCURRENT_RUNS=16

# ============================================================================
# Security
# ============================================================================
# Set true in production to require JWT/API-key auth on protected endpoints.
CORTEX_AUTH_REQUIRED=false
# CHANGE THIS in production — used to sign JWTs (use a long random value).
CORTEX_JWT_SECRET=change-me-to-a-long-random-secret
CORTEX_JWT_ALGORITHM=HS256
CORTEX_JWT_EXPIRE_MINUTES=60
# Comma-separated CORS allowlist
CORTEX_CORS_ORIGINS=http://localhost:8000,http://127.0.0.1:8000
# Per-principal request rate limit
CORTEX_RATE_LIMIT_PER_MINUTE=30
# Max characters accepted in a goal
CORTEX_MAX_GOAL_LENGTH=4000

# ============================================================================
# Server / observability
# ============================================================================
CORTEX_HOST=127.0.0.1
CORTEX_PORT=8000
CORTEX_LOG_LEVEL=INFO
CORTEX_LOG_JSON=true
CORTEX_ENABLE_METRICS=true
CORTEX_ENABLE_TRACING=false
