# cortex-agent configuration — copy to .env and fill in.
# NEVER commit your real .env. All values below are placeholders.

# --- LLM API keys (read directly by the backends; never hardcoded) ----------
# Anthropic Claude (used by --backend anthropic)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# HuggingFace (used by --backend hf, API mode)
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Agent configuration (CORTEX_ prefix) -----------------------------------
# Backend: mock (offline, default), anthropic, or hf
CORTEX_BACKEND=mock
# Model id override. Examples:
#   anthropic: claude-opus-4-8 | claude-sonnet-4-6 | claude-haiku-4-5
#   hf:        Qwen/Qwen2.5-7B-Instruct | meta-llama/Llama-3.1-8B-Instruct
CORTEX_MODEL=
# Max ReAct steps per run
CORTEX_MAX_STEPS=8
# Max output tokens per LLM call
CORTEX_MAX_TOKENS=2048
# Sampling temperature
CORTEX_TEMPERATURE=0.7
# Sandbox directory for file/python tools
CORTEX_WORKSPACE=.cortex/workspace
# SQLite path for long-term memory
CORTEX_MEMORY_DB=.cortex/memory.sqlite
# Enable sentence-transformers vector recall when the package is installed
CORTEX_USE_VECTORS=false
# Expose network tools (http_get) to the agent
CORTEX_ENABLE_NETWORK_TOOLS=true

# --- API server -------------------------------------------------------------
CORTEX_HOST=127.0.0.1
CORTEX_PORT=8000
